generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CaseStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  HEARING_SCHEDULED
  CLOSED
  REJECTED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum NotificationType {
  CASE_UPDATE
  MESSAGE
  PAYMENT
  APPOINTMENT
  SYSTEM
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?
  password     String
  role         UserRole
  profileImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lawyerProfile LawyerProfile?

  clientCases Case[] @relation("ClientCases")
  lawyerCases Case[] @relation("LawyerCases")

  notifications Notification[]
  appointments  Appointment[]
  drafts        Draft[]        @relation("LawyerDrafts")
}

model LawyerProfile {
  id String @id @default(uuid())

  userId String @unique

  specialization  String
  experienceYears Int?

  barCouncilNumber String?
  bio              String?

  consultationFee Float?

  verificationStatus VerificationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Case {
  id String @id @default(uuid())

  title       String
  description String

  category String

  status CaseStatus @default(DRAFT)

  winningProbability Float?

  aiSummary String?

  aiSuggestions String?

  clientId String

  lawyerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client User @relation("ClientCases", fields: [clientId], references: [id])

  lawyer User? @relation("LawyerCases", fields: [lawyerId], references: [id])

  documents    Document[]
  timeline     CaseTimeline[]
  judgments    CaseJudgment[]
  invoices     Invoice[]
  appointments Appointment[]
}

model CaseTimeline {
  id String @id @default(uuid())

  caseId String

  title String

  description String?

  createdAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])
}

model Document {
  id String @id @default(uuid())

  caseId String

  fileName String

  fileUrl String

  uploadedBy String

  createdAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])
}

model Chat {
  id String @id @default(uuid())

  clientId String

  lawyerId String

  createdAt DateTime @default(now())

  messages Message[]
}

model Message {
  id String @id @default(uuid())

  chatId String

  senderId String

  content String

  fileUrl String?

  voiceUrl String?

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

model Appointment {
  id String @id @default(uuid())

  title String

  startTime DateTime

  endTime DateTime

  caseId String?

  userId String

  case Case? @relation(fields: [caseId], references: [id])

  user User @relation(fields: [userId], references: [id])
}

model Invoice {
  id String @id @default(uuid())

  caseId String

  amount Float

  description String?

  status InvoiceStatus @default(PENDING)

  issuedAt DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  userId String

  title String

  message String

  isRead Boolean @default(false)

  type NotificationType

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Judgment {
  id String @id @default(uuid())

  title String

  court String

  year Int

  category String

  citation String?

  summary String

  outcome String

  createdAt DateTime @default(now())

  caseLinks CaseJudgment[]
}

model CaseJudgment {
  id String @id @default(uuid())

  caseId String

  judgmentId String

  relevanceScore Float?

  case Case @relation(fields: [caseId], references: [id])

  judgment Judgment @relation(fields: [judgmentId], references: [id])
}

model LegalAct {
  id String @id @default(uuid())

  name String

  year Int?

  description String?

  sections LegalSection[]
}

model LegalSection {
  id String @id @default(uuid())

  actId String

  sectionNumber String

  title String

  description String

  hindiSummary String?

  punishment String?

  keywords String?

  createdAt DateTime @default(now())

  act LegalAct @relation(fields: [actId], references: [id])
}

model Draft {
  id String @id @default(uuid())

  lawyerId String

  title String

  type String

  content String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  lawyer User @relation("LawyerDrafts", fields: [lawyerId], references: [id])
}
